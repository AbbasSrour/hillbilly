{
  "name": "@hillbilly/rbac",
  "version": "0.0.2",
  "private": true,
  "type": "commonjs",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./client": {
      "types": "./dist/esm/client.d.ts",
      "import": "./dist/esm/client.js",
      "require": "./dist/client.js",
      "default": "./dist/esm/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.js",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.client.json",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:unit": "vitest --include='test/**/*.spec.ts' --run",
    "test:integration": "vitest --include='test/**/*.integration-spec.ts' --run",
    "test:e2e": "vitest --include='test/**/*.e2e-spec.ts' --run",
    "lint": "vp lint packages/rbac",
    "fmt": "vp fmt packages/rbac --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "better-auth": "^1.4.10",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^2.1.8",
    "zod": "^4.2.1"
  },
  "peerDependencies": {
    "better-auth": "^1.4.10",
    "typescript": "latest",
    "zod": "^4.2.1"
  }
}
