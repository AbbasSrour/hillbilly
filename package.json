{
  "name": "hillbilly",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "hillbilly": "src/index.ts"
  },
  "type": "module",
  "scripts": {
    "check": "vp check",
    "check:fix": "vp check --fix",
    "build": "bun run ./scripts/build.ts",
    "dev": "bun run src/index.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "commit": "cz",
    "knip": "knip",
    "release": "release-it"
  },
  "dependencies": {
    "@opentui/core": "^0.2.15",
    "@opentui/react": "^0.2.15",
    "commander": "^14.0.3",
    "diff": "^9.0.0",
    "react": "^19.2.6",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.6",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "release-it": "^20.0.1",
    "vite-plus": "latest",
    "vitest": "^4.1.7"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.14"
}
