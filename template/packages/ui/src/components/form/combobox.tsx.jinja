import { Button } from '@[[ project_name ]]/ui/core/button';
import {
  Command,
  CommandEmpty,
  CommandGroup,
  CommandInput,
  CommandItem,
  CommandList,
} from '@[[ project_name ]]/ui/core/command';
import { Drawer, DrawerContent, DrawerTrigger } from '@[[ project_name ]]/ui/core/drawer';
import { Popover, PopoverContent, PopoverTrigger } from '@[[ project_name ]]/ui/core/popover';
import { Skeleton } from '@[[ project_name ]]/ui/core/skeleton';
import { useIsMobile } from '@[[ project_name ]]/ui/hooks/is-mobile';
import { CommandLoading } from 'cmdk';
import { Check, ChevronsUpDown } from 'lucide-react';
import * as React from 'react';
import { type ComponentPropsWithoutRef, type RefObject, useEffect, useRef } from 'react';
import { useIntersection } from 'react-use';
import { cn } from '../../lib/utils';

export type ComboboxOption = {
  icon?: React.ReactNode;
  value: string;
  label: string;
};

interface ComboboxProps {
  options: ComboboxOption[];
  value: string;
  onChange: (value: string) => void;
  placeholder?: string;
  emptyMessage?: string;
  triggerProps?: ComponentPropsWithoutRef<typeof Button>;
  contentProps?: ComponentPropsWithoutRef<typeof PopoverContent>;
  searchPlaceholder?: string;
  disabled?: boolean;
  onScrollEnd?: () => void;
  isLoading?: boolean;
  searchValue?: string;
  setSearchValue?: (value: string) => void;
}

export function Combobox({
  options,
  value,
  onChange,
  placeholder = 'Select an option...',
  emptyMessage = 'No option found.',
  triggerProps,
  contentProps,
  searchPlaceholder = 'Search...',
  disabled = false,
  isLoading,
  onScrollEnd,
  searchValue,
  setSearchValue,
}: ComboboxProps) {
  const [open, setOpen] = React.useState(false);
  const isMobile = useIsMobile();

  const triggerRef = useRef<HTMLButtonElement | null>(null);
  const [triggerWidth, setTriggerWidth] = React.useState<number | undefined>(undefined);

  useEffect(() => {
    const updateTriggerWidth = () => {
      if (triggerRef.current && 'offsetWidth' in triggerRef.current) {
        setTriggerWidth(triggerRef.current.offsetWidth);
      }
    };

    updateTriggerWidth();
    window.addEventListener('resize', updateTriggerWidth);

    return () => {
      window.removeEventListener('resize', updateTriggerWidth);
    };
  }, []);

  const selectedOption = value ? options.find((option) => option.value === value) : undefined;
  const triggerContent = selectedOption?.label || placeholder;
  const triggerIcon = selectedOption?.icon;

  if (!isMobile) {
    return (
      <Popover open={open} onOpenChange={setOpen}>
        <PopoverTrigger asChild>
          <TriggerButton
            {...triggerProps}
            ref={triggerRef}
            open={open}
            triggerContent={triggerContent}
            icon={triggerIcon}
            disabled={disabled}
          />
        </PopoverTrigger>
        <PopoverContent
          {...contentProps}
          className={cn('p-0', contentProps?.className)}
          align="start"
          style=[% raw %]{{ width: triggerWidth ? `${triggerWidth}px` : undefined }}[% endraw %]
        >
          <OptionsList
            options={options}
            value={value}
            onChange={onChange}
            setOpen={setOpen}
            emptyMessage={emptyMessage}
            searchPlaceholder={searchPlaceholder}
            onScrollEnd={onScrollEnd}
            isLoading={isLoading}
            searchValue={searchValue}
            setSearchValue={setSearchValue}
          />
        </PopoverContent>
      </Popover>
    );
  }

  return (
    <Drawer open={open} onOpenChange={setOpen}>
      <DrawerTrigger asChild>
        <TriggerButton
          {...triggerProps}
          open={open}
          triggerContent={triggerContent}
          icon={triggerIcon}
          disabled={disabled}
        />
      </DrawerTrigger>
      <DrawerContent>
        <div className="mt-4 border-t">
          <OptionsList
            options={options}
            value={value}
            onChange={onChange}
            setOpen={setOpen}
            emptyMessage={emptyMessage}
            searchPlaceholder={searchPlaceholder}
            onScrollEnd={onScrollEnd}
            searchValue={searchValue}
            setSearchValue={setSearchValue}
          />
        </div>
      </DrawerContent>
    </Drawer>
  );
}

interface OptionsListProps extends Omit<ComponentPropsWithoutRef<typeof Command>, 'onChange'> {
  options: ComboboxOption[];
  value: string;
  onChange: (value: string) => void;
  setOpen: (open: boolean) => void;
  emptyMessage: string;
  searchPlaceholder: string;
  onScrollEnd?: () => void;
  searchValue?: string;
  setSearchValue?: (value: string) => void;
}

function OptionsList({
  options,
  value,
  onChange,
  setOpen,
  emptyMessage,
  searchPlaceholder,
  onScrollEnd,
  isLoading,
  searchValue,
  setSearchValue,
  ...props
}: OptionsListProps & { isLoading?: boolean }) {
  const observerRef = useRef<HTMLDivElement>(null);

  const intersection = useIntersection(observerRef as RefObject<HTMLDivElement>, {
    root: null,
    rootMargin: '0px',
    threshold: 1,
  });

  useEffect(() => {
    if (intersection?.isIntersecting && onScrollEnd) {
      onScrollEnd();
    }
  }, [intersection?.isIntersecting, onScrollEnd]);

  return (
    <Command {...props}>
      <CommandInput
        value={searchValue}
        onValueChange={setSearchValue}
        placeholder={searchPlaceholder}
      />
      <CommandList>
        <CommandEmpty>{emptyMessage}</CommandEmpty>
        <CommandGroup>
          {options.map((option) => (
            <CommandItem
              key={option.value}
              value={option.value}
              onSelect={(currentValue) => {
                onChange(currentValue === value ? '' : currentValue);
                setOpen(false);
              }}
            >
              <div className="flex items-center gap-2 capitalize">
                {option.icon}
                {option.label}
              </div>
              <Check
                className={cn('ml-auto', value === option.value ? 'opacity-100' : 'opacity-0')}
              />
            </CommandItem>
          ))}
        </CommandGroup>
        {isLoading && (
          <CommandLoading>
            <CommandGroup>
              {Array.from({ length: 5 }).map((_, index) => (
                <CommandItem
                  // biome-ignore lint/suspicious/noArrayIndexKey: <explanation>
                  key={index}
                  className="flex items-center gap-2"
                  disabled
                >
                  <div className="relative w-full">
                    <div className="flex items-center gap-2">
                      <Skeleton className="h-5 w-5 rounded-full" />
                      <div className="flex-1">
                        <Skeleton className="h-3 w-full mb-1" />
                        <Skeleton className="h-2 w-3/4" />
                      </div>
                    </div>
                  </div>
                </CommandItem>
              ))}
            </CommandGroup>
          </CommandLoading>
        )}
        <div ref={observerRef} className="h-0" />
      </CommandList>
    </Command>
  );
}

interface TriggerButtonProps extends ComponentPropsWithoutRef<typeof Button> {
  open: boolean;
  triggerContent: string;
  disabled: boolean;
  icon?: React.ReactNode;
}

const TriggerButton = React.forwardRef<HTMLButtonElement, TriggerButtonProps>(
  ({ open, triggerContent, disabled, icon, ...props }, ref) => {
    return (
      <Button
        {...props}
        ref={ref}
        variant="outline"
        // biome-ignore lint/a11y/useSemanticElements: I prefer to keep the role as combobox
        role="combobox"
        aria-expanded={open}
        className={cn('w-full justify-between capitalize', props.className)}
        disabled={disabled}
      >
        <div className="flex items-center gap-2">
          {icon}
          {triggerContent}
        </div>
        <ChevronsUpDown className="ml-2 h-4 w-4 shrink-0 opacity-50" />
      </Button>
    );
  },
);
