import {
  FileUpload,
  FileUploadDropzone,
  FileUploadTrigger,
} from '@[[ project_name ]]/ui/components/form/file-upload';
import { Button } from '@[[ project_name ]]/ui/core/button';
import { cn } from '@[[ project_name ]]/ui/lib/utils';
import { CameraIcon, Loader2Icon } from 'lucide-react';
import { type ComponentProps, type ReactNode, useEffect, useMemo } from 'react';

type AvatarInputProps = Omit<ComponentProps<typeof FileUpload>, 'children'> & {
  label: string;
  preview: ReactNode;
  uploading?: boolean;
};

export function AvatarInput({
  label,
  preview,
  uploading = false,
  value,
  className,
  ...props
}: AvatarInputProps) {
  const file = value?.[0];
  const previewUrl = useMemo(() => (file ? URL.createObjectURL(file) : null), [file]);

  useEffect(() => {
    return () => {
      if (previewUrl) {
        URL.revokeObjectURL(previewUrl);
      }
    };
  }, [previewUrl]);

  return (
    <FileUpload value={value} className={cn('w-fit', className)} {...props}>
      <FileUploadDropzone className="size-24 rounded-full border-0 bg-transparent p-0 hover:bg-transparent focus-visible:ring-0">
        <div className="relative size-24 overflow-hidden rounded-full border bg-muted/20">
          {previewUrl ? (
            <img src={previewUrl} alt={label} className="size-full object-cover object-center" />
          ) : (
            preview
          )}

          <div className="absolute inset-0 bg-black/0 transition-colors group-hover:bg-black/10 group-data-[dragging]:bg-black/10" />

          <FileUploadTrigger asChild>
            <Button
              type="button"
              variant="secondary"
              size="icon"
              className="absolute bottom-1 right-1 size-8 rounded-full border shadow-sm"
              disabled={uploading}
            >
              {uploading ? (
                <Loader2Icon className="size-4 animate-spin" />
              ) : (
                <CameraIcon className="size-4" />
              )}
              <span className="sr-only">{label}</span>
            </Button>
          </FileUploadTrigger>
        </div>
      </FileUploadDropzone>
    </FileUpload>
  );
}
