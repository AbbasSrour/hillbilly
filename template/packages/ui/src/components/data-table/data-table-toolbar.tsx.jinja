import { useDataTableContext } from '@[[ project_name ]]/ui/components/data-table/data-table-provider';
import { Button } from '@[[ project_name ]]/ui/core/button';
import { Input } from '@[[ project_name ]]/ui/core/input';
import { useSearch } from '@[[ project_name ]]/ui/hooks/search';
import { Cross2Icon } from '@radix-ui/react-icons';
import { SearchIcon } from 'lucide-react';
import type { PropsWithChildren } from 'react';

interface DataTableToolbarProps {
  placeholder?: string;
}

export function DataTableToolbar({
  placeholder,
  children,
}: PropsWithChildren<DataTableToolbarProps>) {
  const { rawSearchValue, setSearchValue } = useSearch();

  return (
    <div className="flex flex-col-reverse gap-2 sm:flex-row sm:items-center">
      <Input
        placeholder={placeholder}
        icon={SearchIcon}
        value={rawSearchValue}
        onChange={(event) => setSearchValue(event.target.value)}
        className="h-8 w-full sm:w-50 lg:w-100"
      />
      <div className="flex flex-1 flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        {children}
      </div>
    </div>
  );
}

export const DataTableToolbarFilters = ({ children }: PropsWithChildren) => {
  const table = useDataTableContext();

  const { rawSearchValue, setSearchValue } = useSearch();
  const isFiltered =
    table.getState().columnFilters.length > 0 ||
    table.getState().sorting.length > 0 ||
    rawSearchValue.length > 0;

  const resetFilters = () => {
    setSearchValue('');
    table.resetColumnFilters();
    table.resetSorting();
  };

  // TODO this causing issue when filtering by data not present in the table,
  //      check the order list search by serial number
  // useEffect(() => {
  //   const columns = table.getAllColumns();
  //   for (const column of columns) {
  //     if (column.columnDef.meta?.searchable) {
  //       column.setFilterValue(debouncedSearch);
  //     }
  //   }
  // }, [debouncedSearch, table.getAllColumns]);

  return (
    <div className="flex flex-wrap items-center gap-2">
      {children}
      {isFiltered && (
        <Button variant="ghost" onClick={resetFilters} className="h-8 px-2 lg:px-3">
          Reset
          <Cross2Icon className="ml-2 h-4 w-4" />
        </Button>
      )}
    </div>
  );
};

export const DataTableToolbarActions = ({ children }: PropsWithChildren) => {
  const table = useDataTableContext();

  const selectedCount = table.getFilteredSelectedRowModel().rows.length;

  return (
    <div className="flex flex-wrap items-center gap-2">
      {selectedCount > 0 && (
        <div className="flex items-center gap-2 px-3 py-1 bg-muted rounded-md">
          <span className="text-sm font-medium">{selectedCount} selected</span>
        </div>
      )}
      {children}
    </div>
  );
};
