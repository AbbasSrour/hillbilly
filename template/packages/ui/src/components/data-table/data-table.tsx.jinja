import { type Row, type RowData, flexRender } from '@tanstack/react-table';
import { useVirtualizer } from '@tanstack/react-virtual';
import { useDataTableContext } from '@[[ project_name ]]/ui/components/data-table/data-table-provider';
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from '@[[ project_name ]]/ui/core/table';
import { cn } from '@[[ project_name ]]/ui/lib/utils';
import { type MouseEvent, useCallback, useEffect, useRef, useState } from 'react';

interface DataTableProps<TData extends RowData> {
  onRowClick?: (row: Row<TData>, event: MouseEvent<HTMLTableRowElement>) => void;
  enableVirtualization?: boolean;
  estimateRowHeight?: number;
  overscan?: number;
  containerHeight?: string | number;
}

const getColumnClassName = (
  columnIndex: number,
  targetIndex: number,
  originalClassName?: string,
) => {
  if (columnIndex === targetIndex) {
    return cn(
      'drop-shadow-[0_1px_2px_rgb(0_0_0_/_0.1)] dark:drop-shadow-[0_1px_2px_rgb(255_255_255_/_0.1)] lg:drop-shadow-none',
      'bg-background transition-colors duration-200 group-hover/row:bg-muted group-data-[state=selected]/row:bg-muted',
      'sticky md:table-cell',
      originalClassName,
    );
  }

  return originalClassName;
};

export function DataTable<TData extends RowData>({
  onRowClick,
  enableVirtualization = false,
  estimateRowHeight = 42, // Default estimate for row height
  overscan = 5, // Default number of rows to render outside of the visible area
  containerHeight,
}: DataTableProps<TData>) {
  const table = useDataTableContext<TData>();

  const hasSelectColumn = table.getAllColumns().some((column) => column.id === 'select');

  // Refs for virtualization
  const tableContainerRef = useRef<HTMLDivElement>(null);
  const [_tableHeight, setTableHeight] = useState(500);

  // Store row heights in a Map for dynamic height virtualization
  const rowHeights = useRef<Map<string, number>>(new Map());

  // Function to measure row heights
  const measureElement = useCallback((element: Element | null, id: string) => {
    if (element) {
      const height = element.getBoundingClientRect().height;
      if (height !== rowHeights.current.get(id)) {
        rowHeights.current.set(id, height);
        // Notify virtualizer about the height change
        virtualizer?.measure();
      }
    }
  }, []);

  // Get estimated size for a row
  const getRowHeight = useCallback(
    (index: number): number => {
      const row = table.getRowModel().rows[index];
      return row ? rowHeights.current.get(row.id) || estimateRowHeight : estimateRowHeight;
    },
    [table, estimateRowHeight],
  );

  // Setup virtualizer
  const virtualizer = enableVirtualization
    ? useVirtualizer({
        count: table.getRowModel().rows.length,
        getScrollElement: () => tableContainerRef.current,
        estimateSize: getRowHeight,
        overscan,
        getItemKey: (index) => table.getRowModel().rows[index]?.id || index,
        // Adding scrollPadding to account for the sticky header
        scrollPaddingStart:
          tableContainerRef.current?.querySelector('[data-slot="table-header"]')?.clientHeight || 0,
      })
    : null;

  // Calculate virtual rows if virtualization is enabled
  const virtualRows = virtualizer ? virtualizer.getVirtualItems() : [];

  // Update table height based on container size
  // This effect is crucial for proper virtualization
  useEffect(() => {
    if (tableContainerRef.current && enableVirtualization) {
      const tableHeader = tableContainerRef.current.querySelector(
        '[data-slot="table-header"]',
      ) as HTMLElement | null;

      // Create a resize observer for the container
      const containerResizeObserver = new ResizeObserver((entries) => {
        const height = entries[0]?.contentRect.height;
        // Account for header height to calculate available space for the body
        if (height) {
          const headerHeight = tableHeader?.clientHeight || 0;
          setTableHeight(height - headerHeight);
          virtualizer?.measure();
        }
      });

      // Create a separate observer for the header to update scrollPadding
      const headerResizeObserver = tableHeader
        ? new ResizeObserver(() => {
            const headerHeight = tableHeader.clientHeight || 0;
            const containerHeight = tableContainerRef.current?.clientHeight || 0;
            setTableHeight(containerHeight - headerHeight);
            virtualizer?.measure();
          })
        : null;

      containerResizeObserver.observe(tableContainerRef.current);
      if (tableHeader && headerResizeObserver) {
        headerResizeObserver.observe(tableHeader);
      }

      // Initial measurement after mount
      const headerHeight = tableHeader?.clientHeight || 0;
      const containerHeight = tableContainerRef.current?.clientHeight || 0;
      setTableHeight(containerHeight - headerHeight);
      virtualizer?.measure();

      return () => {
        containerResizeObserver.disconnect();
        headerResizeObserver?.disconnect();
      };
    }
  }, [enableVirtualization, virtualizer]);

  const containerStyle = {
    height: containerHeight
      ? typeof containerHeight === 'number'
        ? `${containerHeight}px`
        : containerHeight
      : enableVirtualization
        ? '100%'
        : 'auto',
    overflow: 'auto' as const,
    position: 'relative' as const,
  };

  return (
    <div className="rounded-md border" ref={tableContainerRef} style={containerStyle}>
      <Table>
        <TableHeader data-slot="table-header" className="sticky top-0 z-10 bg-background">
          {table.getHeaderGroups().map((headerGroup) => (
            <TableRow key={headerGroup.id} className="group/row">
              {headerGroup.headers.map((header, _index) => {
                return (
                  <TableHead
                    key={header.id}
                    colSpan={header.colSpan}
                    className={cn(header.column.columnDef.meta?.className)}
                  >
                    {header.isPlaceholder
                      ? null
                      : flexRender(header.column.columnDef.header, header.getContext())}
                  </TableHead>
                );
              })}
            </TableRow>
          ))}
        </TableHeader>
        <TableBody className="relative">
          {table.getRowModel().rows?.length ? (
            enableVirtualization ? (
              // Virtualized rows
              <>
                {/* Add padding to the top to preserve the scroll position */}
                {virtualizer && virtualRows.length > 0 && (
                  <tr
                    style=[% raw %]{{ height: `${virtualRows?.[0]?.start}px` }}[% endraw %]
                    className="virtual-spacer"
                  />
                )}

                {/* Render only the visible rows */}
                {virtualRows.map((virtualRow) => {
                  // biome-ignore lint/style/noNonNullAssertion: <explanation>
                  const row = table.getRowModel().rows[virtualRow.index]!;
                  return (
                    <TableRow
                      key={row.id}
                      data-state={row.getIsSelected() && 'selected'}
                      className={cn('group/row', {
                        'cursor-pointer': onRowClick,
                      })}
                      onDoubleClick={(event) => {
                        onRowClick?.(row, event);
                      }}
                      ref={(el) => measureElement(el, row.id)}
                      data-index={virtualRow.index}
                    >
                      {row.getVisibleCells().map((cell, columnIndex) => (
                        <TableCell
                          key={cell.id}
                          className={getColumnClassName(
                            columnIndex,
                            hasSelectColumn ? 1 : 0,
                            cell.column.columnDef.meta?.className,
                          )}
                        >
                          {flexRender(cell.column.columnDef.cell, cell.getContext())}
                        </TableCell>
                      ))}
                    </TableRow>
                  );
                })}

                {/* Add padding to the bottom to preserve the scroll position */}
                {virtualizer && virtualRows.length > 0 && (
                  <tr
                    className="virtual-spacer"
                    style=[% raw %]{{
                      height: `${virtualizer.getTotalSize() - (virtualRows[virtualRows.length - 1]?.end || 0)}px`,
                    }}[% endraw %]
                  />
                )}
              </>
            ) : (
              // Standard rendering without virtualization
              table.getRowModel().rows.map((row) => (
                <TableRow
                  key={row.id}
                  data-state={row.getIsSelected() && 'selected'}
                  className={cn('group/row', {
                    'cursor-pointer': onRowClick,
                  })}
                  onDoubleClick={(event) => {
                    onRowClick?.(row, event);
                  }}
                >
                  {row.getVisibleCells().map((cell, columnIndex) => (
                    <TableCell
                      key={cell.id}
                      className={getColumnClassName(
                        columnIndex,
                        hasSelectColumn ? 1 : 0,
                        cell.column.columnDef.meta?.className,
                      )}
                    >
                      {flexRender(cell.column.columnDef.cell, cell.getContext())}
                    </TableCell>
                  ))}
                </TableRow>
              ))
            )
          ) : (
            <TableRow>
              <TableCell colSpan={table.getAllColumns().length} className="h-24 text-center">
                No results.
              </TableCell>
            </TableRow>
          )}
        </TableBody>
      </Table>
    </div>
  );
}
