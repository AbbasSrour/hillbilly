import { usePermission } from '@[[ project_name ]]/ui/context/permission';
import { useRecentsStore } from '@[[ project_name ]]/ui/store/recents';
import { useRouterState } from '@tanstack/react-router';
import type { LucideIcon } from 'lucide-react';
import {
  createContext,
  type PropsWithChildren,
  type ReactNode,
  useCallback,
  useContext,
  useEffect,
  useMemo,
} from 'react';

export interface NavigationItem<T extends string = string> {
  title: string;
  url: string;
  icon: LucideIcon;
  permission?: T;
  isActive?: boolean;
  items?: Array<{
    title: string;
    url: string;
    permission?: T;
  }>;
}

export interface MenuAction {
  label: string;
  icon: ReactNode;
  onClick: () => void;
}

export interface MenuActionSection {
  key: string;
  actions: MenuAction[];
}

export interface NavigationContext<T extends string = string> {
  homepage?: string;
  projectName?: string;
  projectDescription?: string;
  user?: {
    name: string;
    identifier: string;
    avatar?: string | null;
  };
  avatarFallback?: {
    gradients?: string[];
    images?: string[];
  };
  userActions?: MenuActionSection[] | MenuAction[];
  main: NavigationItem<T>[];
  secondary?: NavigationItem<T>[];
  enableRecents: boolean;
}

export const NavigationContext = createContext<NavigationContext>({
  homepage: '/',
  main: [],
  secondary: [],
  enableRecents: false,
});

export const useNavigation = () => {
  if (!NavigationContext) {
    throw new Error('useNavigation must be used within a NavigationProvider');
  }

  const context = useContext(NavigationContext);
  const { hasPermission } = usePermission();

  const filterNavigationItems = useCallback(
    (items: NavigationItem[]) => {
      return items
        .filter((item) => hasPermission(item.permission))
        .map((item) => ({
          ...item,
          items: item.items?.filter((subItem) => hasPermission(subItem.permission)),
        }));
    },
    [hasPermission],
  );

  const filteredMain = useMemo(
    () => filterNavigationItems(context.main),
    [context.main, filterNavigationItems],
  );
  const filteredSecondary = useMemo(
    () => filterNavigationItems(context.secondary || []),
    [context.secondary, filterNavigationItems],
  );

  return {
    ...context,
    main: filteredMain,
    secondary: filteredSecondary,
  };
};

export interface NavigationProviderProps {
  homepage?: string;
  projectName?: string;
  projectDescription?: string;
  user?: {
    name: string;
    identifier: string;
    avatar?: string | null;
  };
  avatarFallback?: {
    gradients?: string[];
    images?: string[];
  };
  userActions?: MenuActionSection[] | MenuAction[];
  main: NavigationItem[];
  secondary?: NavigationItem[];
  enableRecents?: boolean;
}

export const NavigationProvider = ({
  children,
  homepage,
  projectName,
  projectDescription,
  user,
  avatarFallback,
  userActions,
  main,
  secondary = [],
  enableRecents = false,
}: PropsWithChildren<NavigationProviderProps>) => {
  const routerState = useRouterState();
  const pathname = routerState.location.pathname;

  useEffect(() => {
    if (!enableRecents || !pathname) return;

    const findMatchingItem = (
      navItems: NavigationItem[],
      currentPath: string,
    ): NavigationItem | null => {
      for (const item of navItems) {
        if (item.url === currentPath) {
          return item;
        }

        const urlPattern = item.url.replace(/\/:[^/]+/g, '/[^/]+');
        const regex = new RegExp(`^${urlPattern}$`);
        if (regex.test(currentPath)) {
          return item;
        }

        if (item.items) {
          for (const subItem of item.items) {
            if (subItem.url === currentPath) {
              return {
                title: subItem.title,
                url: subItem.url,
                icon: item.icon,
              };
            }

            const subUrlPattern = subItem.url.replace(/\/:[^/]+/g, '/[^/]+');
            const subRegex = new RegExp(`^${subUrlPattern}$`);
            if (subRegex.test(currentPath)) {
              return {
                title: subItem.title,
                url: subItem.url,
                icon: item.icon,
              };
            }
          }
        }
      }

      return null;
    };

    const allItems = [...main, ...secondary];
    const matchedItem = findMatchingItem(allItems, pathname);
    if (matchedItem) {
      const pageTitle = document.title.split('|')[0]?.trim() || matchedItem.title;

      useRecentsStore.getState().addRecent({
        name: pageTitle,
        url: pathname,
        icon: matchedItem.icon.displayName || 'File',
      });
    }
  }, [pathname, main, secondary, enableRecents]);

  return (
    <NavigationContext.Provider
      value={{
        homepage,
        projectName,
        projectDescription,
        user,
        avatarFallback,
        userActions,
        main,
        secondary,
        enableRecents,
      }}
    >
      {children}
    </NavigationContext.Provider>
  );
};
