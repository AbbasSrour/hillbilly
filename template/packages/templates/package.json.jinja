{
  "name": "@hillbilly/templates",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./email": "./dist/email/index.js"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json && tsc-alias -p tsconfig.json --resolve-full-paths --resolve-full-extension .js",
    "check": "vp check",
    "fmt": "vp fmt --write",
    "lint": "vp lint",
    "typecheck": "tsc --noEmit",
    "preview": "email dev -d ./src/email"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "latest",
    "react-email": "^6.3.3",
    "tsc-alias": "^1.8.16"
  }
}
