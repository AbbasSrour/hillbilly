{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "language": "ts",
  "sourceRoot": "src",
  "compilerOptions": {
    "tsConfigPath": "./tsconfig.build.json",
    "deleteOutDir": true,
    "plugins": ["@nestjs/swagger/plugin"],
    "assets": [
      {
        "include": "templates/pdf/**/*.hbs",
        "watchAssets": true
      },
      {
        "include": "lib/openapi-description.md",
        "watchAssets": true
      },
      {
        "include": "i18n/locale/**/*.json",
        "watchAssets": true
      }
    ]
  },
  "generateOptions": {
    "baseDir": "./module"
  }
}
