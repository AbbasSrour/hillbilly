{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "language": "ts",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": {
      "type": "rspack",
      "options": {
        "configPath": "rspack.config.cjs"
      }
    },
    "tsConfigPath": "./tsconfig.build.json",
    "typeCheck": false,
    "deleteOutDir": true,
    "plugins": ["@nestjs/swagger/plugin"],
    "assets": [
      {
        "include": "templates/pdf/**/*.hbs",
        "watchAssets": true
      },
      {
        "include": "lib/openapi-description.md",
        "watchAssets": true
      }
    ]
  },
  "generateOptions": {
    "baseDir": "./module"
  }
}
