    "@rspack/core": "^1.6.7",
    "@swc/cli": "^0.7.7",
    "@swc/core": "^1.11.29",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.0",
    "@types/express": "^5.0.2",
    "@types/lodash": "^4.17.17",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.1.4",
    "@vitest/ui": "^3.2.4",
