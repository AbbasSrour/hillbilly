{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "console": "node ./dist/console.js",
    "prebuild": "rm -f tsconfig.build.tsbuildinfo",
    "build": "nest build",
    "postbuild": "tsc-alias -p tsconfig.build.json --resolve-full-paths --resolve-full-extension .js && node scripts/patch-swagger-plugin-output.mjs",
    "check": "vp check",
    "fmt": "vp fmt --write",
    "lint": "vp lint",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:debug": "cross-env TS_NODE_CACHE=false nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "migration:generate": "mikro-orm migration:create",
    "migration:create": "mikro-orm migration:create --blank",
    "migration:update": "mikro-orm migration:up",
    "migration:down": "mikro-orm migration:down",
    "migration:fresh": "mikro-orm migration:fresh",
    "schema:fresh": "mikro-orm schema:fresh -r",
    "schema:drop": "mikro-orm schema:drop --drop-migrations-table -r",
    "seed": "mikro-orm seeder:run",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:cov": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run --project unit",
    "test:unit:watch": "vitest watch --project unit",
    "test:unit:cov": "vitest run --coverage --project unit",
    "test:unit:ui": "vitest --ui --project unit",
    "test:integration": "vitest run --project integration",
    "test:integration:watch": "vitest watch --project integration",
    "test:integration:cov": "vitest run --coverage --project integration",
    "test:integration:ui": "vitest --ui --project integration",
    "test:e2e": "vitest run --project e2e",
    "test:e2e:watch": "vitest watch --project e2e",
    "test:e2e:cov": "vitest run --coverage --project e2e",
    "test:e2e:ui": "vitest --ui --project e2e",
    "new": "bash ./scripts/generate-module.sh",
    "db:backup": "bash ./scripts/backup-data.sh",
    "db:import": "bash ./scripts/import-data.sh",
    "db:init": "bash ./scripts/init-data.sh",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@abbas_srour/nest-openapi-tools": "^6.0.7",
    "@[[ project_name ]]/rbac": "workspace:*",
    "@[[ project_name ]]/templates": "workspace:*",
    "@mikro-orm/cli": "^7.1.1",
    "@mikro-orm/core": "^7.1.1",
    "@mikro-orm/decorators": "^7.1.1",
    "@mikro-orm/entity-generator": "^7.1.1",
    "@mikro-orm/migrations": "^7.1.1",
    "@mikro-orm/nestjs": "^7.0.2",
    "@mikro-orm/postgresql": "^7.1.1",
    "@mikro-orm/reflection": "^7.1.1",
    "@mikro-orm/seeder": "^7.1.1",
    "@mikro-orm/sql": "^7.1.1",
    "@nestjs-modules/mailer": "^2.3.6",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "12.0.0-alpha.5",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "12.0.0-alpha.5",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/microservices": "12.0.0-alpha.5",
    "@nestjs/platform-express": "12.0.0-alpha.5",
    "@nestjs/swagger": "12.0.0-alpha.2",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/instrumentation-express": "^0.66.0",
    "@opentelemetry/instrumentation-fs": "^0.37.0",
    "@opentelemetry/instrumentation-http": "^0.218.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.64.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@scalar/nestjs-api-reference": "^1.1.19",
    "@thallesp/nestjs-better-auth": "^2.6.0",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.6.11",
    "better-auth-mikro-orm": "1.0.0-next.2",
    "bullmq": "^5.77.3",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "libphonenumber-js": "^1.13.3",
    "lodash": "^4.18.1",
    "mime-types": "^3.0.2",
    "morgan": "^1.10.1",
    "nest-commander": "^3.20.1",
    "nestjs-cls": "^6.2.0",
    "nestjs-i18n": "^10.8.4",
    "openapi-merge": "^1.3.3",
    "parse-duration": "^2.1.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "slugify": "^1.6.9",
    "source-map-support": "^0.5.21",
    "swagger-ui-express": "^5.0.1",
    "tslib": "^2.8.1",
    "twilio": "^6.0.2",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@faker-js/faker": "^10.4.0",
    "@[[ project_name ]]/tsconfig": "workspace:*",
    "@mikro-orm/sqlite": "^7.1.1",
    "@nestjs/cli": "12.0.0-alpha.6",
    "@nestjs/schematics": "12.0.0-alpha.9",
    "@nestjs/testing": "12.0.0-alpha.5",
    "@openapitools/openapi-generator-cli": "^2.34.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.40",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@typescript/native-preview": "latest",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "inquirer": "^13.4.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  },
  "mikro-orm": {
    "configPaths": [
      "./dist/lib/mikro-orm.config.js",
      "./src/lib/mikro-orm.config.ts"
    ]
  }
}
