{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "console": "node ./dist/console.js",
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:debug": "cross-env TS_NODE_CACHE=false nest start --debug --watch",
    "start:prod": "node dist/main",
    "migration:generate": "mikro-orm migration:create",
    "migration:create": "mikro-orm migration:create --blank",
    "migration:update": "mikro-orm migration:up",
    "migration:down": "mikro-orm migration:down",
    "migration:fresh": "mikro-orm migration:fresh",
    "schema:fresh": "mikro-orm schema:fresh -r",
    "schema:drop": "mikro-orm schema:drop --drop-migrations-table -r",
    "seed": "mikro-orm seeder:run",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:cov": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run --project unit",
    "test:unit:watch": "vitest watch --project unit",
    "test:unit:cov": "vitest run --coverage --project unit",
    "test:unit:ui": "vitest --ui --project unit",
    "test:integration": "vitest run --project integration",
    "test:integration:watch": "vitest watch --project integration",
    "test:integration:cov": "vitest run --coverage --project integration",
    "test:integration:ui": "vitest --ui --project integration",
    "test:e2e": "vitest run --project e2e",
    "test:e2e:watch": "vitest watch --project e2e",
    "test:e2e:cov": "vitest run --coverage --project e2e",
    "test:e2e:ui": "vitest --ui --project e2e",
    "new": "bash ./scripts/generate-module.sh",
    "db:backup": "bash ./scripts/backup-data.sh",
    "db:import": "bash ./scripts/import-data.sh",
    "db:init": "bash ./scripts/init-data.sh",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@abbas_srour/nest-openapi-tools": "^6.0.7",
    "@[[ project_name ]]/templates": "*",
    "@hillbilly/nest": "*",
    "@hillbilly/rbac": "*",
    "@mikro-orm/cli": "^7.1.0",
