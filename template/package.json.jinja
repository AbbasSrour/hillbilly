{
  "name": "[[ project_name ]]",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "node apps/backend/patches/patch-better-auth-mikro-orm.cjs && node apps/backend/patches/patch-nest-start.cjs",
    "ready": "vp check && vp run -r test && vp run -r build",
    "dev": "vp run dev",
    "build": "vp run build",
    "check": "vp check",
    "lint": "vp run lint",
    "fmt": "vp run fmt",
    "commit": "cz",
    "knip": "knip",
    "release": "release-it",
    "hillbilly": "./bin/hillbilly"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@release-it/conventional-changelog": "^11.0.0",
    "@typescript/native-preview": "latest",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "knip": "^6.14.2",
    "release-it": "^20.0.1",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "@nestjs/cli": "12.0.0-alpha.6",
    "@nestjs/common": "12.0.0-alpha.5",
    "@nestjs/core": "12.0.0-alpha.5",
    "@nestjs/microservices": "12.0.0-alpha.5",
    "@nestjs/platform-express": "12.0.0-alpha.5",
    "@nestjs/schematics": "12.0.0-alpha.9",
    "@nestjs/swagger": "12.0.0-alpha.2",
    "@nestjs/testing": "12.0.0-alpha.5",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.14",
  "//": "TODO: Remove the postinstall Swagger patch when @nestjs/swagger publishes v12 with official Nest 12 support.",
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vite-plus": "latest"
  }
}
