name: Deploy Development Environment

on:
  workflow_dispatch:

env:
  PROJECT_ID: [[ gcp_project_id ]]
  REGION: europe-west1
  PORT: 8080

jobs:
  deploy:
    runs-on: ubuntu-latest
    permissions:
      contents: 'read'
      id-token: 'write'

    strategy:
      matrix:
        include:
          - service: [[ project_name ]]-web-dev
            dockerfile: apps/web/Dockerfile
            build_arg: 'NEXT_PUBLIC_API_URL=none'
          - service: [[ project_name ]]-backend-dev
            dockerfile: apps/backend/Dockerfile
            build_arg: ''

    steps:
      - name: Checkout
        uses: actions/checkout@v6.0.2

      - name: Google Auth
        uses: google-github-actions/auth@v2
        with:
          credentials_json: '[% raw %]${{ secrets.GCP_SECRET }}[% endraw %]'

      - name: Set up Google Cloud SDK
        uses: google-github-actions/setup-gcloud@v2

      - name: Configure Docker
        run: gcloud auth configure-docker "[% raw %]${{ env.REGION }}[% endraw %]-docker.pkg.dev" --quiet

      - name: Short Commit Hash
        run: echo "SHORT_COMMIT=${GITHUB_SHA::7}" >> $GITHUB_ENV

      - name: Resource Name
        run: echo "RESOURCE_NAME=[% raw %]${{ env.REGION }}[% endraw %]-docker.pkg.dev/[% raw %]${{ env.PROJECT_ID }}[% endraw %]/[% raw %]${{ matrix.service }}[% endraw %]/[% raw %]${{ matrix.service }}[% endraw %]:[% raw %]${{ env.SHORT_COMMIT }}[% endraw %]" >> $GITHUB_ENV

      - name: Build and Push Container
        uses: docker/build-push-action@v6
        with:
          context: .
          file: [% raw %]${{ matrix.dockerfile }}[% endraw %]
          build-args: [% raw %]${{ matrix.build_arg }}[% endraw %]
          push: true
          tags: [% raw %]${{ env.RESOURCE_NAME }}[% endraw %]

      - name: Deploy to Cloud Run
        id: deploy
        uses: google-github-actions/deploy-cloudrun@v2
        with:
          service: [% raw %]${{ matrix.service }}[% endraw %]
          region: [% raw %]${{ env.REGION }}[% endraw %]
          image: [% raw %]${{ env.RESOURCE_NAME }}[% endraw %]

      - name: Show Output
        run: echo [% raw %]${{ steps.deploy.outputs.url }}[% endraw %]
